"refs/heads/"
"refs/tags/"
"refs/keys/"

# UUID-like
"00000000-0000-0000-0000-000000000000"
"ffffffff-ffff-ffff-ffff-ffffffffffff"

# Expiry
"0000000000000000"
"ffffffffffffffff"

